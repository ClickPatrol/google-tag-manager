___TESTS___

scenarios:
- name: Injects script with correct URL when page has no query parameters
  code: |-
    mock('getUrl', 'https://example.com/page');
    mock('injectScript', function(url, onSuccess, onFailure) {
      assertThat(url).isEqualTo('https://trck-002.clckptrl.com/?uid=TEST-UID-1234');
      onSuccess();
    });
    runCode({uid: 'TEST-UID-1234'});
    assertApi('gtmOnSuccess').wasCalled();
- name: Appends query parameters from page URL to script URL
  code: |-
    mock('getUrl', 'https://example.com/page?gclid=abc123&utm_source=google');
    mock('injectScript', function(url, onSuccess, onFailure) {
      assertThat(url).isEqualTo('https://trck-002.clckptrl.com/?uid=TEST-UID-1234&gclid=abc123&utm_source=google');
      onSuccess();
    });
    runCode({uid: 'TEST-UID-1234'});
    assertApi('gtmOnSuccess').wasCalled();
- name: Calls gtmOnFailure when script injection fails
  code: |-
    mock('getUrl', 'https://example.com/page');
    mock('injectScript', function(url, onSuccess, onFailure) {
      onFailure();
    });
    runCode({uid: 'TEST-UID-1234'});
    assertApi('gtmOnFailure').wasCalled();


